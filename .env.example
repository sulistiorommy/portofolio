# GitHub API Token (Personal Access Token)
# Create one at https://github.com/settings/tokens
VITE_GITHUB_TOKEN=your_github_token_here

# WakaTime API Key (Optional, for private coding stats)
# Get yours at https://wakatime.com/settings/api-key
VITE_WAKATIME_API_KEY=your_wakatime_key_here

# Formspree ID (For the contact form)
# Get one at https://formspree.io
VITE_FORMSPREE_ID=your_formspree_id_here

# Umami Analytics (Option A: Custom UI Stats)
VITE_UMAMI_WEBSITE_ID=your_website_id_here
VITE_UMAMI_API_KEY=your_umami_api_key_here
VITE_UMAMI_SERVER_URL=https://cloud.umami.is